# Immutable, content-hashed build artifacts and blog assets
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable
/blog/*
  Cache-Control: public, max-age=31536000, immutable

# Prerendered OG images
/og/*
  Cache-Control: public, max-age=86400

# Site images (rarely change, but not content-hashed)
/images/*
  Cache-Control: public, max-age=86400
/static/*
  Cache-Control: public, max-age=86400

# Favicons and app icons (rarely change, but not content-hashed)
/favicon.ico
  Cache-Control: public, max-age=86400
/icon.svg
  Cache-Control: public, max-age=86400
/icon.png
  Cache-Control: public, max-age=86400
/icon-192.png
  Cache-Control: public, max-age=86400
/apple-icon.png
  Cache-Control: public, max-age=86400
/mask-icon.svg
  Cache-Control: public, max-age=86400
/site.webmanifest
  Cache-Control: public, max-age=86400
